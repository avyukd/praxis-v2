# Database
DATABASE_URL=postgresql+asyncpg://praxis:praxis@localhost:5432/praxis
ALEMBIC_DATABASE_URL=postgresql://praxis:praxis@localhost:5432/praxis

# Paths
VAULT_ROOT=/Users/avyukdixit/vault
INBOX_ROOT=/Users/avyukdixit/praxis-inbox
CLAUDE_SESSIONS_ROOT=/tmp/praxis-claude-sessions
LOG_DIR=/var/log/praxis

# LLM invoker (cli | api). API requires explicit set + restart, never fallback.
PRAXIS_INVOKER=cli
# Only set these if PRAXIS_INVOKER=api
# ANTHROPIC_API_KEY=

# Pool
DISPATCHER_POOL_SIZE=4
DISPATCHER_TICK_INTERVAL_S=2
WORKER_LEASE_S=300
WORKER_HEARTBEAT_INTERVAL_S=60
CLI_NO_EVENT_TIMEOUT_S=60
CLI_WALL_CLOCK_TIMEOUT_S=600

# Rate limits
RATE_LIMIT_INITIAL_BACKOFF_S_MIN=180
RATE_LIMIT_INITIAL_BACKOFF_S_MAX=300
RATE_LIMIT_MAX_BACKOFF_S=3600

# Priority — min % of slots reserved per tier
PRIORITY_P0_MIN_PCT=0.40
PRIORITY_P1_MIN_PCT=0.25
PRIORITY_P2_MIN_PCT=0.15
PRIORITY_P3_MIN_PCT=0.10
PRIORITY_P4_MIN_PCT=0.10
AGE_BUMP_AFTER_MIN=30

# EDGAR
SEC_USER_AGENT=praxis-v2 research-admin@praxis.local
EDGAR_POLL_INTERVAL_S=60
EDGAR_FORM_TYPES=8-K

# ntfy
NTFY_BASE_URL=https://ntfy.sh
NTFY_ALERT_TOPIC=praxis-alerts
NTFY_SIGNAL_TOPIC=praxis-signals

# Restic
RESTIC_REPOSITORY=s3:s3.amazonaws.com/praxis-backups
RESTIC_PASSWORD_FILE=/etc/praxis/restic.password
RESTIC_SNAPSHOT_INTERVAL_S=3600

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# MCP server
MCP_HOST=127.0.0.1
MCP_PORT=8765

# Market hours (ET)
MARKET_OPEN_ET=08:00
MARKET_CLOSE_ET=16:00
MARKET_TIMEZONE=America/New_York
