[Unit]
Description=praxis-v2 inbox poller
After=network.target postgresql.service

[Service]
Type=simple
User=avyuk
Group=avyuk
WorkingDirectory=/home/avyuk/dev/praxis-v2
EnvironmentFile=/home/avyuk/dev/praxis-v2/.env
ExecStart=/home/avyuk/dev/praxis-v2/.venv/bin/python -m services.pollers.inbox_watcher
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
