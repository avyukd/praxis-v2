[Unit]
Description=praxis-v2 scheduler + dead-man switch
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=praxis
Group=praxis
WorkingDirectory=/opt/praxis-v2
EnvironmentFile=/etc/praxis/praxis.env
ExecStart=/opt/praxis-v2/.venv/bin/python -m services.scheduler.main
Restart=always
RestartSec=10
StartLimitBurst=5
StartLimitIntervalSec=120
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
